{
  "name": "esimmongolia",
  "version": "1.0.0",
  "private": true,
  "description": "eSIM Mongolia — web + Capacitor mobile app",
  "scripts": {
    "www:sync": "node scripts/sync-www.mjs",
    "cap:sync": "npm run www:sync && npx cap sync",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "assets:generate": "npx @capacitor/assets generate --iconBackgroundColor \"#2563eb\" --iconBackgroundColorDark \"#1d4ed8\" --splashBackgroundColor \"#2563eb\" --splashBackgroundColorDark \"#1d4ed8\"",
    "build:android:debug": "npm run cap:sync && cd android && gradlew.bat assembleDebug",
    "build:android:release": "npm run cap:sync && cd android && gradlew.bat assembleRelease",
    "verify:mobile": "node scripts/verify-mobile-setup.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.2",
    "@capacitor/browser": "^6.0.4",
    "@capacitor/camera": "^6.1.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/filesystem": "^6.0.2",
    "@capacitor/geolocation": "^6.0.2",
    "@capacitor/haptics": "^6.0.2",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/network": "^6.0.3",
    "@capacitor/preferences": "^6.0.3",
    "@capacitor/push-notifications": "^6.0.3",
    "@capacitor/splash-screen": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.2.0"
  },
  "engines": {
    "node": ">=18"
  }
}
