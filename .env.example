# eSIM Mongolia — local / Netlify env (copy to .env, do not commit secrets)

# Supabase project: esimmongolia (dedicated)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# OpenAI — travel AI assistant (server-side only, never in frontend)
OPENAI_API_KEY=sk-your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# QPay (Netlify production)
# QPAY_USERNAME=
# QPAY_PASSWORD=
# QPAY_INVOICE_CODE=ESIM_MGL_INVOICE
# SITE_URL=https://esimmongolia.com

# Admin API
# ADMIN_SECRET=

# Cloudinary — unsigned upload preset (no API secret in frontend)
CLOUDINARY_CLOUD_NAME=dflwo8gmz
CLOUDINARY_UPLOAD_PRESET=esimmongolia_upload
