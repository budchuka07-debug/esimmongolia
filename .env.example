# eSIM Mongolia — local / Netlify env (copy to .env, do not commit secrets)

# Supabase project: esimmongolia (dedicated)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# QPay (Netlify production)
# QPAY_USERNAME=
# QPAY_PASSWORD=
# QPAY_INVOICE_CODE=ESIM_MGL_INVOICE
# SITE_URL=https://esimmongolia.com

# Admin API
# ADMIN_SECRET=

# Cloudinary (unsigned upload preset — no API secret in frontend)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset
